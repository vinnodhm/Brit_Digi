# Britannia Digi Print — Environment Variables
# Copy this file as .env in the project root and fill in your values

# ── Neon DB connection string ──────────────────────────────────────────
# Get yours from: https://console.neon.tech
DATABASE_URL=postgresql://username:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ── Razorpay Test Keys ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_TEST_KEY=rzp_test_REPLACE_WITH_YOUR_KEY
